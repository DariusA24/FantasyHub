datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id               Int               @id @default(autoincrement())
  clerkId          String            @unique
  firstName        String
  lastName         String
  username         String
  email            String
  profileImage     String
  bio              String?
  updatedAt        DateTime          @updatedAt
  sleeperProfileId String?
  sleeperProfile   sleeperProfile?
  hubLeagues           HubLeague[]
  hubLeagueMemberships HubLeagueMember[]        @relation("ProfileMemberships")
  managerProfiles      HubLeagueManagerProfile[] @relation("ManagerProfiles")
  authoredPosts        HubLeaguePost[]           @relation("AuthoredPosts")
  postLikes            HubLeaguePostLike[]       @relation("PostLikes")
  postComments         HubLeaguePostComment[]    @relation("PostComments")
  forumPosts           ForumPost[]               @relation("AuthoredForumPosts")
  forumPostLikes       ForumPostLike[]           @relation("ForumPostLikes")
  forumPostComments    ForumPostComment[]        @relation("ForumPostComments")
  playerChatMessages   PlayerChat[]              @relation("PlayerChatMessages")
  awards               HubLeagueAward[]          @relation("AwardedProfiles")
  seasonStats          HubLeagueSeasonStat[]     @relation("SeasonStats")
  wallets              Wallet[]                  @relation("ProfileWallets")
  createdBets          Bet[]                     @relation("BetCreator")
  takenBets            Bet[]                     @relation("BetTaker")
  startSitVotes        StartSitVote[]            @relation("StartSitVotes")
  predictionStat       UserPredictionStat?       @relation("PredictionStat")
}

model sleeperProfile {
  id          Int      @id @default(autoincrement())
  sleeperId   String   @unique
  displayName String
  avatar      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profileId   Int      @unique
  profile     Profile  @relation(fields: [profileId], references: [id])
}

model SleeperPlayer {
  id        String   @id // sleeper player_id
  full_name String?
  position  String?
  team      String?
  rawJson   Json     // store entire Sleeper payload if you want
  updatedAt DateTime @updatedAt
  maddenStats  maddenPlayer[]
  chatMessages PlayerChat[]
}

model HubLeague {
  id          String            @id @default(cuid())
  name        String
  description String?
  ownerId     Int
  owner       Profile           @relation(fields: [ownerId], references: [id])
  seasons         HubLeagueSeason[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  members         HubLeagueMember[]        @relation("LeagueMembers")
  managerProfiles HubLeagueManagerProfile[]
  posts           HubLeaguePost[]
  champions       HubLeagueChampion[]
  awards          HubLeagueAward[]
  seasonStats     HubLeagueSeasonStat[]
  h2hRecords      HubLeagueH2H[]
  wallets         Wallet[]
  bets            Bet[]
}

model HubLeagueChampion {
  id          String   @id @default(cuid())
  hubLeagueId String
  season      String   // e.g. "2024"
  winnerName  String
  teamName    String?
  wins        Int
  losses      Int
  ties        Int      @default(0)
  notes       String?
  variant     String   @default("classic") // "classic" | "diamond" | "obsidian" | "ruby" | "emerald"
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hubLeague HubLeague @relation(fields: [hubLeagueId], references: [id], onDelete: Cascade)

  @@unique([hubLeagueId, season])
  @@index([hubLeagueId])
}

model HubLeaguePost {
  id          String   @id @default(cuid())
  hubLeagueId String
  authorId    Int
  tag         String   // "Recap" | "Trade" | "Power Rankings" | "Trash Talk" | "Injury" | "News"
  weekLabel   String
  title       String
  body        String
  excerpt     String
  readTime    String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hubLeague HubLeague            @relation(fields: [hubLeagueId], references: [id], onDelete: Cascade)
  author    Profile              @relation("AuthoredPosts", fields: [authorId], references: [id])
  likes     HubLeaguePostLike[]
  comments  HubLeaguePostComment[]

  @@index([hubLeagueId])
  @@index([authorId])
}

model HubLeaguePostLike {
  id        Int      @id @default(autoincrement())
  postId    String
  profileId Int
  value     Int      // 1 = like, -1 = dislike
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    HubLeaguePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  profile Profile       @relation("PostLikes", fields: [profileId], references: [id])

  @@unique([postId, profileId])
  @@index([postId])
}

model HubLeaguePostComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  Int
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   HubLeaguePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Profile       @relation("PostComments", fields: [authorId], references: [id])

  @@index([postId])
  @@index([authorId])
}

model HubLeagueSeason {
  id              String    @id @default(cuid())
  hubLeagueId     String
  hubLeague       HubLeague @relation(fields: [hubLeagueId], references: [id])
  sleeperLeagueId String
  season          String
  sleeperName     String?
  sleeperSport    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sleeperLeagueId])
  @@index([hubLeagueId, season])
}

model HubLeagueManagerProfile {
  id                Int      @id @default(autoincrement())
  hubLeagueId       String
  profileId         Int
  bio               String?
  playerStyle       String?
  playerStyleSub    String?
  favoriteAsset     String?
  favoriteAssetSub  String?
  tradeActivity     String?
  tradeActivitySub  String?
  favoritePlayerId  String?
  favoritePlayerSub String?
  mode              String?
  modeSub           String?
  rival             String?
  rivalSub          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  hubLeague HubLeague @relation(fields: [hubLeagueId], references: [id])
  profile   Profile   @relation("ManagerProfiles", fields: [profileId], references: [id])

  @@unique([hubLeagueId, profileId])
  @@index([profileId])
}

// NEW: join table between HubLeague and Profile to represent membership
model HubLeagueMember {
  id          Int       @id @default(autoincrement())
  hubLeagueId String
  profileId   Int

  hubLeague   HubLeague @relation("LeagueMembers", fields: [hubLeagueId], references: [id])
  profile     Profile   @relation("ProfileMemberships", fields: [profileId], references: [id])

  role        String    @default("member") // e.g. "member", "co-owner", etc.
  createdAt   DateTime  @default(now())

  @@unique([hubLeagueId, profileId])
  @@index([profileId])
}

model maddenPlayer {
  id           String   @map("id")
  full_name    String?
  position     String?
  team         String?
  year         Int
  week         Int
  overall      Int?
  shared_stats Json?    @default("{}")
  qb_stats     Json?    @default("{}")
  wr_stats     Json?    @default("{}")
  te_stats     Json?    @default("{}")
  rb_stats     Json?    @default("{}")
  k_stats      Json?    @default("{}")
  created_at   DateTime? @default(now()) @db.Timestamptz

  sleeperPlayer SleeperPlayer @relation(fields: [id], references: [id])

  @@id([id, year, week])
  @@index([id])
  @@map("maddenPlayer")
}

model HubLeagueH2H {
  id                  String   @id @default(cuid())
  hubLeagueId         String
  season              String
  sleeperUserId       String
  opponentUserId      String
  opponentDisplayName String
  opponentAvatar      String?
  wins                Int      @default(0)
  losses              Int      @default(0)
  ties                Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  hubLeague HubLeague @relation(fields: [hubLeagueId], references: [id], onDelete: Cascade)

  @@unique([hubLeagueId, season, sleeperUserId, opponentUserId])
  @@index([hubLeagueId, sleeperUserId])
}

model HubLeagueSeasonStat {
  id            String   @id @default(cuid())
  hubLeagueId   String
  season        String
  sleeperUserId String
  profileId     Int?
  wins          Int
  losses        Int
  ties          Int      @default(0)
  pointsFor     Float
  pointsAgainst Float
  highWeek      Float
  lowWeek       Float
  rank          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hubLeague HubLeague @relation(fields: [hubLeagueId], references: [id], onDelete: Cascade)
  profile   Profile?  @relation("SeasonStats", fields: [profileId], references: [id])

  @@unique([hubLeagueId, season, sleeperUserId])
  @@index([hubLeagueId, season])
  @@index([profileId])
}

model HubLeagueAward {
  id            String   @id @default(cuid())
  hubLeagueId   String
  season        String
  sleeperUserId String
  profileId     Int?
  type          String
  label         String
  description   String
  value         String?
  week          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hubLeague HubLeague @relation(fields: [hubLeagueId], references: [id], onDelete: Cascade)
  profile   Profile?  @relation("AwardedProfiles", fields: [profileId], references: [id])

  @@unique([hubLeagueId, season, type, sleeperUserId])
  @@index([hubLeagueId, season])
  @@index([profileId])
}

model Wallet {
  id          String   @id @default(cuid())
  hubLeagueId String
  profileId   Int
  balance     Int      @default(10000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hubLeague HubLeague @relation(fields: [hubLeagueId], references: [id], onDelete: Cascade)
  profile   Profile   @relation("ProfileWallets", fields: [profileId], references: [id])

  @@unique([hubLeagueId, profileId])
  @@index([profileId])
}

// ─── Global Forum ─────────────────────────────────────────────────────────────

model ForumPost {
  id          String   @id @default(cuid())
  authorId    Int
  tag         String   // "Trade Advice" | "Waiver Wire" | "Start/Sit" | "Draft" | "Trash Talk" | "Playoffs" | "News" | "General"
  title       String
  body        String
  excerpt     String
  readTime    String
  mediaUrls   String[] @default([])
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   Profile            @relation("AuthoredForumPosts", fields: [authorId], references: [id])
  likes    ForumPostLike[]
  comments ForumPostComment[]

  @@index([authorId])
  @@index([publishedAt])
  @@index([tag])
}

model ForumPostLike {
  id        Int      @id @default(autoincrement())
  postId    String
  profileId Int
  value     Int      // 1 = upvote, -1 = downvote
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  profile Profile   @relation("ForumPostLikes", fields: [profileId], references: [id])

  @@unique([postId, profileId])
  @@index([postId])
}

model ForumPostComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  Int
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Profile   @relation("ForumPostComments", fields: [authorId], references: [id])

  @@index([postId])
  @@index([authorId])
}

model Bet {
  id          String    @id @default(cuid())
  hubLeagueId String
  creatorId   Int
  takerId     Int?
  type        String    // "season" | "h2h"
  title       String
  description String?
  amount      Int
  status      String    @default("open") // "open" | "accepted" | "settled" | "cancelled"
  result      String?   // "creator" | "taker" | "push"
  season      String?
  week        Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  settledAt   DateTime?

  hubLeague HubLeague @relation(fields: [hubLeagueId], references: [id], onDelete: Cascade)
  creator   Profile   @relation("BetCreator", fields: [creatorId], references: [id])
  taker     Profile?  @relation("BetTaker", fields: [takerId], references: [id])

  @@index([hubLeagueId])
  @@index([creatorId])
  @@index([takerId])
}

// ─── Start / Sit Community Voting ────────────────────────────────────────────

model StartSitMatchup {
  id        String         @id @default(cuid())
  playerKey String         // sorted sleeper IDs joined: "id1_id2_id3"
  week      Int
  season    String
  createdAt DateTime       @default(now())
  votes     StartSitVote[]

  @@unique([playerKey, week, season])
  @@index([week, season])
}

model StartSitVote {
  id             String          @id @default(cuid())
  matchupId      String
  matchup        StartSitMatchup @relation(fields: [matchupId], references: [id], onDelete: Cascade)
  profileId      Int
  profile        Profile         @relation("StartSitVotes", fields: [profileId], references: [id])
  chosenPlayerId String
  createdAt      DateTime        @default(now())

  correct        Boolean?        // null = ungraded, true/false = resolved after week ends

  @@unique([matchupId, profileId])
  @@index([matchupId])
  @@index([profileId])
  @@index([profileId, correct])
}

model UserPredictionStat {
  id           String   @id @default(cuid())
  profileId    Int      @unique
  totalVotes   Int      @default(0)
  correctPicks Int      @default(0)
  streak       Int      @default(0)
  bestStreak   Int      @default(0)
  tier         String   @default("rookie") // "rookie" | "analyst" | "expert" | "legend"
  updatedAt    DateTime @updatedAt

  profile Profile @relation("PredictionStat", fields: [profileId], references: [id])

  @@index([tier, correctPicks])
}

// ─── Player Discussion Chat ────────────────────────────────────────────────────

model PlayerChat {
  id        String   @id @default(cuid())
  playerId  String
  authorId  Int
  body      String
  createdAt DateTime @default(now())

  player SleeperPlayer @relation(fields: [playerId], references: [id])
  author Profile       @relation("PlayerChatMessages", fields: [authorId], references: [id])

  @@index([playerId, createdAt])
  @@index([authorId])
}
